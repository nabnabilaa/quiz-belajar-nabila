# ─────────────────────────────────────────────────────────────────────────
#  Copy this file to ".env"  (without the .example) and fill in your values.
#  NEVER share .env or commit it to git — it holds your database password.
# ─────────────────────────────────────────────────────────────────────────

# These non-secret values come from your Aiven "Connection information" page.
MYSQL_HOST=mysql-2a811788-fouramber0-7c88.i.aivencloud.com
MYSQL_PORT=23473
MYSQL_USER=avnadmin
MYSQL_DATABASE=defaultdb

# ⚠️ Paste your *rotated* password here (reset it in Aiven first — the one you
#    pasted in chat should be considered compromised). Keep the quotes off.
MYSQL_PASSWORD=

# Path to the Aiven CA certificate. In the Aiven console open
# "CA certificate → Show/Download" and save the file here as ca.pem
MYSQL_SSL_CA=./ca.pem

# Local web server port
PORT=3000

# (Optional) Instead of the 5 vars above you may use a single URL:
# DATABASE_URL=mysql://avnadmin:YOUR_NEW_PASSWORD@mysql-2a811788-fouramber0-7c88.i.aivencloud.com:23473/defaultdb
